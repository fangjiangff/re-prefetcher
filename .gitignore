# Python cache and local environments
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# Build outputs and generated binaries
bin/
/sms/bin/
/stride-prefetcher/bin/
/cmc/bin/
/attacks/bin/
/src/bin/

# Generated local result/cache directories
/cmc/res/
.matplotlib/

# Ignore local editor/OS files
*.swp
*.swo
*.bak
.DS_Store
*.tmp
*~

# Logs and temporary outputs
*.log
*.out
*.err
core
core.*

# Track only the selected gadget-detection sources
/gadget_detect/*
!/gadget_detect/LLVM_FIX/
!/gadget_detect/LLVM_FIX/**
!/gadget_detect/codes/
/gadget_detect/codes/*
!/gadget_detect/codes/search_gadget.sh
